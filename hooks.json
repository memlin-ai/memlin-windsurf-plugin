{
  "hooks": {
    "pre_user_prompt": [
      {
        "command": "node ./dist/hooks/session-start.js",
        "show_output": true
      }
    ],
    "pre_write_code": [
      {
        "command": "node ./dist/hooks/pre-tool-use.js",
        "show_output": true
      }
    ],
    "pre_run_command": [
      {
        "command": "node ./dist/hooks/pre-tool-use.js",
        "show_output": true
      }
    ],
    "pre_mcp_tool_use": [
      {
        "command": "node ./dist/hooks/pre-tool-use.js",
        "show_output": true
      }
    ],
    "post_write_code": [
      {
        "command": "node ./dist/hooks/post-tool-use.js"
      }
    ],
    "post_cascade_response_with_transcript": [
      {
        "command": "node ./dist/hooks/stop.js"
      }
    ]
  }
}
