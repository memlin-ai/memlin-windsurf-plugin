{
  "version": 1,
  "status": "provisional",
  "note": "Windsurf hook event names may change; entrypoints are packaged to mirror Memlin's full adapter contract.",
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node ./dist/hooks/session-start.js",
        "timeout": 10
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "node ./dist/hooks/user-prompt-submit.js",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "node ./dist/hooks/pre-tool-use.js",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "node ./dist/hooks/post-tool-use.js",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node ./dist/hooks/stop.js",
        "timeout": 15
      }
    ]
  }
}
